import cv2
import numpy as np
import matplotlib.pyplot as plt

img = cv2.imread('runway.png', cv2.IMREAD_GRAYSCALE)

img_log = np.log1p(np.array(img, dtype="float"))


fft = np.fft.fft2(img_log)
fft_shift = np.fft.fftshift(fft)

rows, cols = img.shape
crow, ccol = rows//2, cols//2

H = np.ones((rows, cols))
for i in range(rows):
    for j in range(cols):
        d = (i-crow)**2 + (j-ccol)**2
        H[i,j] = 1 - np.exp(-d / (2*(30**2)))  # Gaussian HPF

# Step 4: Apply filter
filtered = fft_shift * H

# Step 5: Inverse FFT
ifft_shift = np.fft.ifftshift(filtered)
img_back = np.fft.ifft2(ifft_shift)
img_back = np.real(img_back)

# Step 6: Exponential
img_exp = np.expm1(img_back)

# Normalize
img_final = np.uint8(np.clip(img_exp, 0, 255))

# Show
plt.imshow(img_final, cmap='gray')
plt.title('Homomorphic Filtered')
plt.axis('off')
plt.show()
