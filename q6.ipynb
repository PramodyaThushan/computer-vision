import sympy as sp

x, y, sigma = sp.symbols('x y sigma', positive=True)

G = (1 / (2 * sp.pi * sigma**2)) * sp.exp(-(x**2 + y**2) / (2 * sigma**2))

dG_dx = sp.diff(G, x)
dG_dy = sp.diff(G, y)

print("∂G/∂x =", dG_dx)
print("∂G/∂y =", dG_dy)

