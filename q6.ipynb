import numpy as np

def gaussian_derivative_kernels(size, sigma):
    k = size // 2
    x, y = np.meshgrid(np.arange(-k, k+1), np.arange(-k, k+1))

    # Gaussian
    G = (1/(2*np.pi*sigma**2)) * np.exp(-(x**2 + y**2)/(2*sigma**2))

    # Derivatives
    Gx = -(x / sigma**2) * G
    Gy = -(y / sigma**2) * G

    # Normalize (sum of absolute values = 1)
    Gx = Gx / np.sum(np.abs(Gx))
    Gy = Gy / np.sum(np.abs(Gy))

    return Gx, Gy

Gx, Gy = gaussian_derivative_kernels(5, 2)

print("Gx:\n", Gx)
print("Gy:\n", Gy)

#===============================

import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

Gx_51, _ = gaussian_derivative_kernels(51, 2)

x = np.arange(51)
y = np.arange(51)
X, Y = np.meshgrid(x, y)

fig = plt.figure()
ax = fig.add_subplot(111, projection='3d')

ax.plot_surface(X, Y, Gx_51)
ax.set_title("Derivative of Gaussian (X-direction)")

plt.show()

