def contrast_stretching_lut(img, r1, r2):
    t = np.zeros(256, dtype=np.uint8)
    for i in range(256):
        r = i / 255.0
        if r < r1:
            t[i] = 0
        elif r <= r2:
            t[i] = int(((r - r1) / (r2 - r1)) * 255)
        else:
            t[i] = 255
    return cv.LUT(img, t)

stretched = contrast_stretching_lut(f,0.2,0.8)

axes[1, 1].imshow(stretched, cmap='gray')
axes[1, 1].set_title('Contrast Stretched (r1=0.2, r2=0.8)')

stretched = contrast_stretching_lut(g_2,0.2,0.8)

axes[2, 0].imshow(stretched, cmap='gray')
axes[2, 0].set_title('Contrast Stretched with Gamma correction with γ = 2 (r1=0.2, r2=0.8)')

