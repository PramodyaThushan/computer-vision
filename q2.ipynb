#Q2

import cv2
import numpy as np
import matplotlib.pyplot as plt

img = cv2.imread('highlights_and_shadows.jpg')
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

lab = cv2.cvtColor(img_rgb, cv2.COLOR_RGB2LAB)

L, A, B = cv2.split(lab)

L_norm = L / 255.0

#gamma = 0.2
#gamma = 0.5
gamma = 0.7
#gamma = 0.9
L_corrected = np.power(L_norm, gamma)

L_corrected = np.uint8(L_corrected * 255)

lab_corrected = cv2.merge((L_corrected, A, B))

img_corrected = cv2.cvtColor(lab_corrected, cv2.COLOR_LAB2RGB)

plt.figure(figsize=(10,5))

plt.subplot(1,2,1)
plt.imshow(img_rgb)
plt.title('Original Image')
plt.axis('off')

plt.subplot(1,2,2)
plt.imshow(img_corrected)
plt.title(f'Gamma Corrected (γ={gamma})')
plt.axis('off')

plt.show()

plt.figure(figsize=(10,5))

plt.subplot(1,2,1)
plt.hist(L.flatten(), bins=256, range=[0,256], color='gray')
plt.title('Original L Channel Histogram')

plt.subplot(1,2,2)
plt.hist(L_corrected.flatten(), bins=256, range=[0,256], color='gray')
plt.title('Corrected L Channel Histogram')

plt.show()
