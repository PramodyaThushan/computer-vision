import cv2
import numpy as np
import matplotlib.pyplot as plt

img = cv2.imread('window_women.jpg')
assert img is not None, "Image not found"

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

thresh_value, binary_mask = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)

print(f"(a) Otsu threshold value = {thresh_value}")

foreground_mask = binary_mask  # white = foreground


gray_equalized_foreground = gray.copy()

foreground_pixels = gray[foreground_mask == 255]

if len(foreground_pixels) > 0:

    equalized_foreground = cv2.equalizeHist(foreground_pixels.reshape(-1,1).astype(np.uint8))

    gray_equalized_foreground[foreground_mask == 255] = equalized_foreground.flatten()

gray_equalized_full = cv2.equalizeHist(gray)

fig, axes = plt.subplots(2, 3, figsize=(15, 10))

axes[0,0].imshow(gray, cmap='gray')
axes[0,0].set_title('Original Grayscale')
axes[0,0].axis('off')

axes[0,1].imshow(foreground_mask, cmap='gray')
axes[0,1].set_title(f'Foreground Mask (Otsu = {thresh_value})')
axes[0,1].axis('off')

axes[0,2].imshow(gray_equalized_full, cmap='gray')
axes[0,2].set_title('Full Image Histogram Equalization')
axes[0,2].axis('off')

axes[1,0].imshow(gray_equalized_foreground, cmap='gray')
axes[1,0].set_title('Foreground-Only Equalization')
axes[1,0].axis('off')

# Histograms
axes[1,1].hist(gray.ravel(), bins=50, range=[0,256], alpha=0.5, label='Original')
axes[1,1].hist(gray_equalized_foreground.ravel(), bins=50, range=[0,256], alpha=0.5, label='Foreground EQ')
axes[1,1].set_title('Histogram Comparison')
axes[1,1].legend()

axes[1,2].axis('off')

plt.tight_layout()
plt.show()
