import numpy as np

def zoom_image(img, scale, method='nearest'):
    h, w = img.shape
    new_h, new_w = int(h * scale), int(w * scale)

    zoomed = np.zeros((new_h, new_w), dtype=img.dtype)

    for i in range(new_h):
        for j in range(new_w):
            # Map back to original image
            x = i / scale
            y = j / scale

            if method == 'nearest':
                xi = int(round(x))
                yj = int(round(y))
                xi = min(xi, h - 1)
                yj = min(yj, w - 1)
                zoomed[i, j] = img[xi, yj]

            elif method == 'bilinear':
                x1 = int(np.floor(x))
                y1 = int(np.floor(y))
                x2 = min(x1 + 1, h - 1)
                y2 = min(y1 + 1, w - 1)

                dx = x - x1
                dy = y - y1

                # Bilinear interpolation
                val = (img[x1, y1] * (1 - dx) * (1 - dy) +
                       img[x2, y1] * dx * (1 - dy) +
                       img[x1, y2] * (1 - dx) * dy +
                       img[x2, y2] * dx * dy)

                zoomed[i, j] = int(val)

    return zoomed


def normalized_ssd(img1, img2):
    diff = img1.astype(float) - img2.astype(float)
    ssd = np.sum(diff ** 2)
    norm_ssd = ssd / (img1.shape[0] * img1.shape[1])
    return norm_ssd

#================================
import cv2
import matplotlib.pyplot as plt

# Load images
small = cv2.imread('im01small.png', cv2.IMREAD_GRAYSCALE)
large = cv2.imread('im01.png', cv2.IMREAD_GRAYSCALE)


scale = large.shape[0] / small.shape[0]


zoom_nn = zoom_image(small, scale, method='nearest')
zoom_bl = zoom_image(small, scale, method='bilinear')


ssd_nn = normalized_ssd(zoom_nn, large)
ssd_bl = normalized_ssd(zoom_bl, large)

print("Normalized SSD (Nearest):", ssd_nn)
print("Normalized SSD (Bilinear):", ssd_bl)

#=====================================

plt.figure(figsize=(12,4))

plt.subplot(1,3,1)
plt.imshow(large, cmap='gray')
plt.title('Original Large')
plt.axis('off')

plt.subplot(1,3,2)
plt.imshow(zoom_nn, cmap='gray')
plt.title('Nearest Neighbor')

plt.subplot(1,3,3)
plt.imshow(zoom_bl, cmap='gray')
plt.title('Bilinear')

plt.show()
