import numpy as np

def bilateral_filter_manual(img, d, sigma_s, sigma_r):
    h, w = img.shape
    pad = d // 2

    padded = np.pad(img, pad, mode='reflect')
    output = np.zeros_like(img, dtype=float)

    for i in range(h):
        for j in range(w):
            i_p, j_p = i + pad, j + pad
            center = padded[i_p, j_p]

            W = 0
            value = 0

            for x in range(-pad, pad+1):
                for y in range(-pad, pad+1):
                    neighbor = padded[i_p + x, j_p + y]

                    # Spatial weight
                    gs = np.exp(-(x**2 + y**2) / (2 * sigma_s**2))

                    # Range weight
                    gr = np.exp(-((neighbor - center)**2) / (2 * sigma_r**2))

                    wgt = gs * gr

                    value += neighbor * wgt
                    W += wgt

            output[i, j] = value / W

    return np.clip(output, 0, 255).astype(np.uint8)

#=======================================
import cv2

img = cv2.imread('sapphire.jpg', cv2.IMREAD_GRAYSCALE)

gaussian = cv2.GaussianBlur(img, (5,5), 2)

bilateral_cv = cv2.bilateralFilter(img, d=5, sigmaColor=50, sigmaSpace=50)

bilateral_manual = bilateral_filter_manual(img, d=5, sigma_s=50, sigma_r=50)

import matplotlib.pyplot as plt

plt.figure(figsize=(12,4))

plt.subplot(1,4,1)
plt.imshow(img, cmap='gray')
plt.title('Original')
plt.axis('off')

plt.subplot(1,4,2)
plt.imshow(gaussian, cmap='gray')
plt.title('Gaussian')
plt.axis('off')

plt.subplot(1,4,3)
plt.imshow(bilateral_cv, cmap='gray')
plt.title('Bilateral (OpenCV)')
plt.axis('off')

plt.subplot(1,4,4)
plt.imshow(bilateral_manual, cmap='gray')
plt.title('Bilateral (Manual)')
plt.axis('off')

plt.show()
