import cv2
import numpy as np
import matplotlib.pyplot as plt


def hist_equalization(img):
    # Flatten image
    flat = img.flatten()

    # Step 1: Histogram
    hist = np.zeros(256, dtype=int)
    for pixel in flat:
        hist[pixel] += 1

    # Step 2: Normalize histogram (PDF)
    pdf = hist / len(flat)

    # Step 3: CDF
    cdf = np.cumsum(pdf)

    # Step 4: Mapping (0–255)
    mapping = np.round(cdf * 255).astype(np.uint8)

    # Step 5: Apply mapping
    equalized = mapping[flat]
    equalized = equalized.reshape(img.shape)

    return equalized

# ---- Load Image ----
img = cv2.imread('runway.png', cv2.IMREAD_GRAYSCALE)  # sample runway image

# Apply custom equalization
eq_img = hist_equalization(img)

# ---- Plot Images ----
plt.figure(figsize=(10,5))

plt.subplot(1,2,1)
plt.imshow(img, cmap='gray')
plt.title('Original Image')
plt.axis('off')

plt.subplot(1,2,2)
plt.imshow(eq_img, cmap='gray')
plt.title('Equalized Image')
plt.axis('off')

plt.show()

# ---- Histograms ----
plt.figure(figsize=(10,5))

plt.subplot(1,2,1)
plt.hist(img.flatten(), bins=256, range=[0,256])
plt.title('Original Histogram')

plt.subplot(1,2,2)
plt.hist(eq_img.flatten(), bins=256, range=[0,256])
plt.title('Equalized Histogram')

plt.show()
