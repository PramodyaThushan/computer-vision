import numpy as np
import cv2

def add_salt_pepper_noise(image, prob=0.02):
    noisy = image.copy()
    h, w = image.shape

    # Salt (white)
    num_salt = int(prob * h * w / 2)
    coords = [np.random.randint(0, i - 1, num_salt) for i in image.shape]
    noisy[coords[0], coords[1]] = 255

    # Pepper (black)
    num_pepper = int(prob * h * w / 2)
    coords = [np.random.randint(0, i - 1, num_pepper) for i in image.shape]
    noisy[coords[0], coords[1]] = 0

    return noisy

img = cv2.imread('emma.jpg', cv2.IMREAD_GRAYSCALE)
noisy_img = add_salt_pepper_noise(img, prob=0.5)

plt.figure(figsize=(15,10))

plt.subplot(1,3,1)
plt.imshow(noisy_img, cmap='gray')
plt.title('Original Image')
plt.axis('off')

gaussian = cv2.GaussianBlur(noisy_img, (5,5), 1)

plt.subplot(1,3,2)
plt.imshow(gaussian, cmap='gray')
plt.title('Gaussian Smoothing')
plt.axis('off')

median = cv2.medianBlur(noisy_img, 7)

plt.subplot(1,3,3)
plt.imshow(median, cmap='gray')
plt.title('Median Filtering')
plt.axis('off')

plt.show()
